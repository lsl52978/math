{
  "name": "mermaid-svg-renderer",
  "version": "0.1.0",
  "description": "Tiny and fast Mermaid to SVG renderer / 最小最快的 Mermaid 转 SVG 渲染器",
  "keywords": [
    "diagram",
    "flowchart",
    "mermaid",
    "render",
    "svg"
  ],
  "homepage": "https://github.com/lsl52978/math",
  "license": "MulanPSL-2.0",
  "author": "i18n.site@gmail.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsl52978/math.git"
  },
  "files": [
    "lib/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/svg.d.ts",
      "default": "./src/svg.js"
    },
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "bun dev.js",
    "build": "bun minify.js && bun sh/bench/mermaid.js && bun demo/build.js",
    "pages:build": "bun install --linker hoisted && bun minify.js && node demo/build.js",
    "pages:deploy": "bun run build && bunx wrangler pages deploy demo/dist --project-name math",
    "test": "bun minify.js && bun test test/compare.test.js",
    "prepare": "husky"
  },
  "dependencies": {},
  "devDependencies": {
    "@1-/mdimg2cdn": "^0.1.1",
    "@1-/mdt": "^0.1.9",
    "@3-/log": "^0.1.9",
    "@3-/read": "^0.1.4",
    "@3-/stylfmt": "^0.1.7",
    "@3-/stylus": "^0.1.17",
    "@3-/write": "^0.0.2",
    "@3-/zx": "^0.1.18",
    "@opencode-ai/sdk": "^1.17.6",
    "browserslist": "^4.28.2",
    "cli-table3": "^0.6.5",
    "husky": "^9.1.7",
    "js-yaml": "^4.2.0",
    "knip": "^6.16.1",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "pug": "^3.0.4",
    "rolldown": "^1.1.1",
    "simple-git": "^3.36.0",
    "svgo": "^4.0.1",
    "vite": "^8.0.16",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "**/*.svg": "bun sh/hook/svg.js",
    "**/*.styl": "bun sh/hook/styl.js"
  }
}
