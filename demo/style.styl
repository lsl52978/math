@import './webc/I18n/_.styl'
@import './webc/Lg/_.styl'
@import './webc/Scroll/_.styl'

:root
  --accent-color #2563eb
  --accent-glow #2563eb14
  --accent-gradient linear-gradient(135deg, #3b82f6 0, #2563eb 100%)
  --accent-hover #1d4ed8
  --bg-color #f8fafc
  --border-color #e2e8f0
  --card-bg #ffffff
  --input-bg #f8fafc
  --page-background #ffffff url('./svg/bg.svg') no-repeat center / cover
  --page-bg #ffffff
  --panel-bg #f8fafc
  --shadow-color #0000000d
  --success-color #10b981
  --text-color #0f172a
  --text-muted #64748b
  --theme-shell-bg #ffffffd9

  &[data-theme='mint']
    --accent-color #14b8a6
    --accent-glow #14b8a61a
    --accent-gradient linear-gradient(135deg, #2dd4bf 0, #0f766e 100%)
    --accent-hover #0f766e
    --bg-color #f0fdfa
    --border-color #99f6e4
    --card-bg #fbfffe
    --input-bg #f0fdfa
    --page-background radial-gradient(circle at 20% 10%, #ccfbf1 0, transparent 32%), linear-gradient(135deg, #ecfeff 0, #f0fdfa 55%, #ccfbf1 100%)
    --page-bg #ecfeff
    --panel-bg #f0fdfa
    --shadow-color #0f766e14
    --text-color #134e4a
    --text-muted #0f766e
    --theme-shell-bg #fbfffee0

  &[data-theme='dracula']
    --accent-color #ff79c6
    --accent-glow #ff79c61f
    --accent-gradient linear-gradient(135deg, #bd93f9 0, #ff79c6 100%)
    --accent-hover #bd93f9
    --bg-color #1f2130
    --border-color #44475a
    --card-bg #282a36
    --input-bg #1f2130
    --page-background radial-gradient(circle at 18% 12%, #3b3054 0, transparent 34%), linear-gradient(135deg, #191a24 0, #282a36 58%, #1f2130 100%)
    --page-bg #191a24
    --panel-bg #21222c
    --shadow-color #00000040
    --text-color #f8f8f2
    --text-muted #bd93f9
    --theme-shell-bg #282a36e6

  &[data-theme='solarized']
    --accent-color #268bd2
    --accent-glow #268bd21f
    --accent-gradient linear-gradient(135deg, #2aa198 0, #268bd2 100%)
    --accent-hover #2aa198
    --bg-color #eee8d5
    --border-color #d6cdb4
    --card-bg #fdf6e3
    --input-bg #eee8d5
    --page-background radial-gradient(circle at 18% 12%, #eee8d5 0, transparent 36%), linear-gradient(135deg, #fdf6e3 0, #eee8d5 58%, #f5e8bf 100%)
    --page-bg #fdf6e3
    --panel-bg #eee8d5
    --shadow-color #657b831f
    --text-color #073642
    --text-muted #657b83
    --theme-shell-bg #fdf6e3e6

body, input, select, button, textarea
  font-family t, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif

html, body
  height 100%
  overflow hidden

body
  background var(--page-background)
  background-attachment fixed
  box-sizing border-box
  color var(--text-color)
  display flex
  flex-direction column
  margin 0
  padding 0

header
  position fixed
  right 24px
  top 24px
  z-index 100

.header-controls
  align-items center
  display flex
  gap 16px

.site-theme
  align-items center
  backdrop-filter blur(12px)
  background var(--theme-shell-bg)
  border 1px solid var(--border-color)
  border-radius 999px
  box-shadow 0 8px 24px var(--shadow-color)
  display flex
  gap 6px
  padding 5px

.theme-chip
  background transparent
  border 0
  border-radius 999px
  color var(--text-muted)
  cursor pointer
  font-size 12px
  font-weight 700
  padding 7px 13px
  transition background-color 0.2s, color 0.2s, box-shadow 0.2s

  &.active
    background var(--card-bg)
    box-shadow 0 2px 8px var(--shadow-color)
    color var(--text-color)

c-i18n
  display flex

.header-controls .BtnC
  align-items center
  display flex
  justify-content center

  .Ico
    align-items center
    display flex
    justify-content center
    position relative

  svg
    color var(--text-muted)
    fill currentColor
    height 20px
    transition color 0.2s
    width 20px

  &:hover svg
    color var(--text-color)

.header-main
  align-items center
  display flex
  flex-direction column
  gap 12px
  margin 31px auto 56px
  max-width 800px
  text-align center

  h1
    font-size 44px
    font-variation-settings 'wght' 250
    font-weight 250
    letter-spacing -1.2px
    margin 0

    a
      color var(--text-color)
      text-decoration none
      text-shadow 0 1px 18px var(--shadow-color)
      transition opacity 0.2s

      &:hover
        opacity 0.85

  .subtitle
    color var(--text-muted)
    font-size 18px
    font-weight 400
    line-height 1.5
    margin 0
    text-align center

.subtitle a
  color var(--accent-color)
  font-weight 600
  text-decoration none
  transition color 0.2s

  &:hover
    color var(--accent-hover)
    text-decoration underline

main
  display flex
  flex 1
  justify-content center
  padding 24px

.container
  display flex
  flex-direction column
  gap 40px
  max-width 1200px
  width 100%

.card
  background var(--card-bg)
  border 1px solid var(--border-color)
  border-radius 24px
  box-shadow 0 4px 6px -1px var(--shadow-color), 0 2px 4px -1px #00000008
  flex-direction column
  padding 32px
  position relative
  z-index 1

  h2
    color var(--text-color)
    font-size 22px
    font-weight 700
    margin-bottom 8px
    margin-top 0

.card-header
  align-items center
  display flex
  justify-content space-between
  margin-bottom 12px

  h2
    margin 0

  .Btn
    font-size 13px
    font-weight 600
    --btnBg linear-gradient(180deg, #f5f5f580, #f5f5f5b3)
    --btnPadding 6px 16px

.tag
  align-items center
  background-color var(--accent-glow)
  border 1px solid #2563eb26
  border-radius 9999px
  box-shadow 0 1px 2px #00000005
  color var(--accent-color)
  display inline-flex
  font-size 13px
  font-weight 600
  padding 6px 14px
  text-decoration none
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

  &:hover
    background-color var(--accent-color)
    border-color var(--accent-color)
    box-shadow 0 4px 6px -1px #2563eb26
    color #ffffff
    transform translateY(-1px)

.editor-card
  display flex
  flex-direction column
  gap 20px

.editor-header
  display flex
  flex-direction column

  h2
    margin-bottom 4px

.tip
  color var(--text-muted)
  font-size 15px
  font-weight 300
  margin 0

#diagram-input
  background-color var(--input-bg)
  border 1px solid var(--border-color)
  border-radius 10px
  box-sizing border-box
  color var(--text-color)
  field-sizing content
  font-family c, monospace
  font-size 18px
  height auto
  line-height 1.6
  max-height 260px
  min-height 220px
  outline none
  overflow auto
  padding 20px
  resize vertical
  transition border-color 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease
  width 100%

  &:focus
    background-color var(--card-bg)
    border-color var(--accent-color)
    box-shadow 0 0 0 3px var(--accent-glow)

.svg-display
  align-items flex-start
  background var(--panel-bg)
  border 1px solid var(--border-color)
  border-radius 16px
  display flex
  justify-content center
  max-height 520px
  min-height 260px
  overflow auto
  padding 24px

  svg
    height auto
    max-height 420px
    max-width 100%
    min-width 240px
    width auto

.diagrams-section
  display flex
  flex-direction column
  gap 24px

  h2
    color var(--text-color)
    font-size 24px
    font-weight 700
    margin 0

.diagrams-grid
  position relative
  transition height 0.3s ease
  width 100%

  .diagram-card
    background var(--card-bg)
    border-radius 16px
    box-shadow 0 4px 6px -1px #0000000d, 0 2px 4px -1px #00000008
    box-sizing border-box
    cursor pointer
    display flex
    flex-direction column
    gap 12px
    padding 24px
    position absolute
    transition transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s

    &:hover
      box-shadow 0 12px 20px -3px #00000014, 0 4px 6px -2px #00000008
      transform translateY(-4px)

      &::before
        background linear-gradient(180deg, #f5f5f580, #f5f5f5b3)

      &::after
        background-image linear-gradient(180deg, var(--accent-color), #2563eb4d)

    h3
      color var(--text-color)
      font-size 18px
      font-weight 600
      margin 0

    .diagram-code
      background-color var(--bg-color)
      border 1px solid var(--border-color)
      border-radius 8px
      color var(--text-muted)
      font-family c, monospace
      font-size 14px
      max-height 150px
      overflow-x auto
      padding 12px 16px
      white-space pre

    .rendered-diagram
      align-items center
      background-color var(--panel-bg)
      border 1px solid var(--border-color)
      border-radius 10px
      display flex
      justify-content center
      min-height 100px
      overflow hidden
      padding 24px

      svg
        height auto
        width 100%

.code-block
  background-color var(--panel-bg)
  border 1px solid var(--border-color)
  border-radius 10px
  margin 0
  padding 24px
  white-space pre-wrap
  word-wrap break-word

  code
    color var(--text-color)
    font-family c, monospace
    font-size 14px
    font-weight 300
    line-height 1.6

.main-grid
  align-items start
  display grid
  gap 40px
  grid-template-columns 1fr 360px
  width 100%

.benchmark-card
  display flex
  flex-direction column

.benchmark-img-container
  align-items center
  display flex
  flex 1
  flex-direction column
  justify-content center
  padding 16px 0

  img
    height auto
    max-width 100%
    width 100%

.benchmark-header
  align-items baseline
  display flex
  flex-wrap wrap
  gap 8px
  justify-content space-between
  margin-bottom 12px

.benchmark-card
  h2
    color var(--text-color)
    font-size 22px
    font-weight 700
    margin 0

  .tip
    color var(--text-muted)
    font-size 14px

@media (max-width 768px)
  header
    right 16px
    top 16px

  .header-main
    margin 46px auto 0

    h1
      font-size 32px

  .header-content
    align-items center
    flex-direction column
    gap 6px
    text-align center

  .subtitle
    border-left none
    padding-left 0

  .main-grid
    display flex
    flex-direction column

  .usage-card
    order 1

  .size-card
    order 2

  .speed-card
    order 3

  .editor-card
    order 4